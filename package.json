{
  "name": "permask",
  "version": "3.0.0",
  "type": "module",
  "description": "A lightweight utility library for managing permission bitmasks with groups and access levels",
  "workspaces": [
    "playground/**"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/integrations/*/index.d.ts",
      "import": "./dist/integrations/*/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "bunx vite build",
    "check": "bun run lint && bun run typecheck && bun run test -- --run && bun run build",
    "test": "bunx vitest",
    "test:coverage": "bunx vitest run --coverage",
    "typecheck": "bunx tsc -p tsconfig.json --noEmit",
    "lint": "bunx biome check .",
    "lint:fix": "bun run lint -- --write",
    "prepare": "bunx is-ci || bunx husky",
    "husky:pre-commit": "bun run lint",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.3",
    "@types/node": "^26.1.1",
    "@typescript/typescript6": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.10",
    "elysia": "^1.4.29",
    "fastify": "^5.10.0",
    "h3": "^1.15.11",
    "hono": "^4.12.30",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "itty-router": "^5.0.24",
    "reflect-metadata": "^0.2.2",
    "semantic-release": "^25.0.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@types/express": "^4.17.0 || ^5.0.0",
    "@types/koa": "^2.0.0 || ^3.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "elysia": "^1.0.0",
    "express": "^4.18.0 || ^5.0.0",
    "fastify": "^4.0.0 || ^5.0.0",
    "h3": "^1.0.0 || ^2.0.0-0",
    "hono": "^4.0.0",
    "itty-router": "^5.0.0",
    "koa": "^2.0.0",
    "nitropack": "^2.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@types/express": {
      "optional": true
    },
    "@types/koa": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "h3": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "itty-router": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "nitropack": {
      "optional": true
    },
    "reflect-metadata": {
      "optional": true
    }
  },
  "files": [
    "dist/*",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "bitmask",
    "access",
    "permissions",
    "authorization",
    "auth",
    "hono",
    "nest",
    "express",
    "itty-router"
  ],
  "author": "dschewchenko",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dschewchenko/permask/issues"
  },
  "homepage": "https://github.com/dschewchenko/permask#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/dschewchenko/permask.git"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      "@semantic-release/git"
    ],
    "branches": [
      "main"
    ]
  },
  "publishConfig": {
    "provenance": true
  },
  "overrides": {
    "@isaacs/brace-expansion": "5.0.1",
    "@sigstore/core": "3.2.1",
    "ajv": "8.20.0",
    "brace-expansion": "2.0.3",
    "diff": "8.0.4",
    "fast-uri": "3.1.3",
    "handlebars": "4.7.9",
    "ip-address": "10.2.0",
    "js-yaml": "4.3.0",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "minimatch": "9.0.9",
    "picomatch": "2.3.2",
    "rollup": "4.62.2",
    "sigstore": "4.1.1",
    "tar": "7.5.20",
    "undici": "7.28.0"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.0.0"
  }
}
